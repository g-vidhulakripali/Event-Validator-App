<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- Semi-transparent black color -->
    <!-- #80 is 50% opacity. Adjust the first two characters (00 to FF) for transparency -->
    <solid android:color="#80000000" />

    <!-- Rounded corners -->
    <corners android:radius="12dp" />

    <!-- Optional: Add padding so content doesn't touch the edges -->
    <padding
        android:left="8dp"
        android:top="4dp"
        android:right="8dp"
        android:bottom="4dp" />

</shape>